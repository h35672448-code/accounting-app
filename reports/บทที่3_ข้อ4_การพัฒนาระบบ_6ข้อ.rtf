ed = fileHeader.map(normalizeHeaderText);\line   const expected = HEADER.map(normalizeHeaderText);\line   for (let i = 0; i < expected.length; i++) \{\line     if (!headerCellMatches(cleaned[i], expected[i])) \{\line       throw new Error("\u3627?\u3633?\u3623?\u3605?\u3634?\u3619?\u3634?\u3591?\u3652?\u3617?\u3656?\u3605?\u3619?\u3591?\u3588?\u3629?\u3621?\u3633?\u3617?\u3609?\u3660? " + (i+1));\line     \}\line   \}\line \}\line\par\pard\f0\cf1\fs24 \u3629?\u3608?\u3636?\u3610?\u3634?\u3618?: \u3611?\u3657?\u3629?\u3591?\u3585?\u3633?\u3609?\u3585?\u3634?\u3619?\u3609?\u3635?\u3648?\u3586?\u3657?\u3634?\u3612?\u3636?\u3604?\u3588?\u3629?\u3621?\u3633?\u3617?\u3609?\u3660? \u3648?\u3594?\u3656?\u3609? \u3618?\u3657?\u3634?\u3618?\u3605?\u3635?\u3649?\u3627?\u3609?\u3656?\u3591? Dr/Cr \u3627?\u3619?\u3639?\u3629?\u3592?\u3635?\u3609?\u3623?\u3609?\u3648?\u3591?\u3636?\u3609? \u3607?\u3635?\u3651?\u3627?\u3657?\u3586?\u3657?\u3629?\u3617?\u3641?\u3621?\u3618?\u3633?\u3591?\u3588?\u3591?\u3617?\u3634?\u3605?\u3619?\u3600?\u3634?\u3609?\u3648?\u3604?\u3637?\u3618?\u3623?\u3585?\u3633?\u3609?\par\par\pard\cf2\b\f0\fs32 \u3586?\u3657?\u3629? 6: \u3626?\u3656?\u3591?\u3629?\u3629?\u3585?\u3652?\u3615?\u3621?\u3660? Excel \u3605?\u3634?\u3617?\u3619?\u3634?\u3618?\u3585?\u3634?\u3619?\u3607?\u3637?\u3656?\u3648?\u3621?\u3639?\u3629?\u3585? (downloadSelected)\b0\cf1\fs26\par\pard\f1\cf3\fs22 function downloadSelected(indexes) \{\line   const all = readAll();\line   const header = all[0];\line   const rows = (indexes || []).map(i => all[i]).filter(Boolean);\line   const xlsxBlob = buildXlsx([header].concat(rows));\line   return \{ name: "\u3607?\u3632?\u3648?\u3610?\u3637?\u3618?\u3609?\u3588?\u3640?\u3617?_\u3626?\u3656?\u3591?\u3629?\u3629?\u3585?.xlsx", data: Utilities.base64Encode(xlsxBlob.getBytes()) \};\line \}\line\par\pard\f0\cf1\fs24 \u3629?\u3608?\u3636?\u3610?\u3634?\u3618?: \u3648?\u3621?\u3639?\u3629?\u3585?\u3648?\u3593?\u3614?\u3634?\u3632?\u3649?\u3606?\u3623